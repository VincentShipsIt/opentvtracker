# Production fails closed unless all App Attest identity and token fields are set.
APP_ATTEST_MODE=production
APP_ATTEST_TEAM_ID=YOUR_APPLE_TEAM_ID
APP_ATTEST_BUNDLE_ID=your.bundle.identifier
APP_ATTEST_TOKEN_SECRET=generate-a-random-value-with-at-least-32-characters
APP_ATTEST_STATE_PATH=./data/app-attest-devices.json
APP_ATTEST_CHALLENGE_TTL_SECONDS=60
APP_ATTEST_TOKEN_TTL_SECONDS=600

# Dedicated read-only TMDB API Read Access Token for this proxy only.
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token

# Emergency controls. Set any feature flag to false without rebuilding.
PROXY_ENABLED=true
CATALOG_ENABLED=true
CINEMA_ENABLED=true
APP_ATTEST_REGISTRATION_ENABLED=true

# Optional. Native iOS clients do not need CORS. This never replaces App Attest.
CORS_ALLOWED_ORIGIN=
PORT=8787

# Development only: change APP_ATTEST_MODE and use one untracked random bypass token.
# APP_ATTEST_MODE=development
# APP_ATTEST_DEVELOPMENT_BYPASS_TOKEN=untracked-local-random-value

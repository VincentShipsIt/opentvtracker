<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>OpenTV Tracker</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CKSharingSupported</key>
	<true/>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.entertainment</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_opentv-pair._tcp</string>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>OpenTV uses the local network only when you choose to pair with your partner's nearby iPhone.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>OpenTV uses the microphone only while you speak a request for your next movie or show.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>OpenTV turns your spoken discovery request into text so it can find matching movies and shows.</string>
	<key>OpenRouterModel</key>
	<string>$(OPENROUTER_MODEL)</string>
	<key>OpenRouterOAuthCallbackURL</key>
	<string>$(OPENROUTER_OAUTH_CALLBACK_URL)</string>
	<key>OpenRouterSiteURL</key>
	<string>$(OPENROUTER_SITE_URL)</string>
	<key>TraktClientID</key>
	<string>$(TRAKT_CLIENT_ID)</string>
	<key>TraktClientSecret</key>
	<string>$(TRAKT_CLIENT_SECRET)</string>
	<key>OpenTVAPIBaseURL</key>
	<string>$(CATALOG_PROXY_BASE_URL)</string>
	<key>OpenTVAppAttestDevelopmentToken</key>
	<string>$(APP_ATTEST_DEVELOPMENT_TOKEN)</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
</dict>
</plist>
